# Server
NODE_ENV=production
PORT=5000
SERVER_URL=https://family-mart-production.up.railway.app

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@familymart-cluster.mongodb.net/family-mart?retryWrites=true&w=majority

# JWT (REQUIRED - must be set in Railway environment variables)
JWT_SECRET=
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# Frontend URLs
FRONTEND_URL=https://testsubjectvivek-pixel.github.io/family-mart-

# Cloudinary (REQUIRED for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=familymart

# Razorpay (Optional - for payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SendGrid (Optional - for emails)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@familymart.com
